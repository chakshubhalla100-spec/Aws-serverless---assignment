4. Automatic EBS Snapshot and Cleanup Using AWS Lambda and Boto3

************************* boto3 code ***********************************

Lambda code 
import json
import logging
from datetime import datetime, timedelta, timezone
import boto3

logger = logging.getLogger()
logger.setLevel(logging.INFO)

VOLUME_ID = "YOUR_VOLUME_ID" 
RETENTION_DAYS = 30

def lambda_handler(event, context):
    ec2 = boto3.client('ec2')
    current_time = datetime.now(timezone.utc)
    
    # 1. CREATE SNAPSHOT WITH TAG IN ONE SINGLE CALL
    try:
        snapshot = ec2.create_snapshot(
            VolumeId=VOLUME_ID,
            Description=f"Automated backup for {VOLUME_ID} on {current_time.strftime('%Y-%m-%d')}",
            TagSpecifications=[{
                'ResourceType': 'snapshot',
                'Tags': [{'Key': 'AutomatedBackup', 'Value': 'True'}]
            }]
        )
        logger.info(f"CREATED_SNAPSHOT: {snapshot['SnapshotId']} for volume {VOLUME_ID}")
    except Exception as e:
        logger.error(f"Failed to create snapshot: {str(e)}")
        raise e

    # 2. LIST AND PURGE SNAPSHOTS OLDER THAN RETENTION WINDOW
    try:
        filters = [{'Name': 'tag:AutomatedBackup', 'Values': ['True']}]
        snapshots = ec2.describe_snapshots(OwnerIds=['self'], Filters=filters)['Snapshots']
        
        for snap in snapshots:
            snap_id = snap['SnapshotId']
            age_days = (current_time - snap['StartTime']).days
            
            if age_days > RETENTION_DAYS:
                ec2.delete_snapshot(SnapshotId=snap_id)
                logger.info(f"DELETED_SNAPSHOT: {snap_id} (Age: {age_days} days old)")
                
    except Exception as e:
        logger.error(f"Failed during cleanup cycle: {str(e)}")
        raise e
        
    return {
        'statusCode': 200,
        'body': json.dumps('EBS backup and cleanup cycle complete.')
    }

