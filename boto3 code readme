3.Monitor Unencrypted S3 Buckets Using AWS Lambda and Boto3

************** boto3 code ********************************************

import boto3
from botocore.exceptions import ClientError

def lambda_handler(event, context):
    s3_client = boto3.client('s3')
    
    try:
        response = s3_client.list_buckets()
        buckets = response.get('Buckets', [])
        
        print(f"Found {len(buckets)} total buckets. Checking compliance...\n")
        non_compliant_buckets = []
        
        for bucket in buckets:
            bucket_name = bucket['Name']
            
            try:
                # Fetch encryption configuration
                enc_resp = s3_client.get_bucket_encryption(Bucket=bucket_name)
                rules = enc_resp['ServerSideEncryptionConfiguration']['Rules']
                
                # Check the exact encryption algorithm used
                for rule in rules:
                    algo = rule['ApplyServerSideEncryptionByDefault']['SSEAlgorithm']
                    
                    # Flag buckets using basic SSE-S3 (AES256) instead of custom KMS keys
                    if algo == 'AES256':
                        non_compliant_buckets.append(bucket_name)
                        
            except ClientError as e:
                error_code = e.response['Error']['Code']
                print(f"Could not read encryption for {bucket_name}: {error_code}")
        
        # Log results
        if non_compliant_buckets:
            print("⚠️ WARNING: The following buckets use basic SSE-S3 instead of corporate KMS encryption:")
            for bucket in non_compliant_buckets:
                print(f" - {bucket}")
        else:
            print("✅ Success: All S3 buckets comply with KMS encryption standards.")
            
        return {
            'statusCode': 200,
            'body': f"Checked {len(buckets)} buckets. Found {len(non_compliant_buckets)} basic-encrypted buckets."
        }
        
    except Exception as e:
        print(f"An unexpected error occurred: {e}")
        return {'statusCode': 500, 'body': "Error processing S3 check."}

