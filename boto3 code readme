2.Automated S3 Bucket Cleanup Using AWS Lambda and Boto3

*********************boto3 code *********************

import boto3
from datetime import datetime, timezone, timedelta

# Create S3 client
s3 = boto3.client('s3')

# Your bucket name
bucket_name = 'aws-chakshu20-04-test'

def lambda_handler(event, context):

    
    old_date = datetime.now(timezone.utc) - timedelta(days=3)

    
    objects = s3.list_objects_v2(Bucket=bucket_name)

   
    if 'Contents' in objects:

        for file in objects['Contents']:

            file_name = file['Key']
            file_date = file['LastModified']

            # Check old files
            if file_date < old_date:

                # Delete file
                s3.delete_object(
                    Bucket=bucket_name,
                    Key=file_name
                )

                print(f"Deleted: {file_name}")

    return {
        'statusCode': 200,
        'body': 'Old files deleted successfully'
    }
